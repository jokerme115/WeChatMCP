WECHATMCP_CONFIG=./wechatmcp.config.json
WECHATMCP_LOCAL_CONFIG=./wechatmcp.local.json
WECHATMCP_TRANSPORT=stdio
WECHATMCP_HOST=127.0.0.1
WECHATMCP_PORT=3333
WECHATMCP_ENDPOINT=/mcp
WECHATMCP_HEALTH_ENABLED=true
WECHATMCP_HEALTH_PATH=/health
WECHATMCP_HEALTH_MESSAGE=ok
WECHATMCP_HEALTH_STATUS=200

WEAPP_AUTOMATOR_MODE=launch
WEAPP_PROJECT_PATH=
WEAPP_WS_ENDPOINT=
WEAPP_DEVTOOLS_PORT=9420
WEAPP_DEVTOOLS_TIMEOUT=30000
WECHAT_DEVTOOLS_CLI_PATH=C:\path\to\wechat-devtools\cli.bat
WEAPP_TRUST_PROJECT=true
