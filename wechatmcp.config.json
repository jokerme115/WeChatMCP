{
  "server": {
    "name": "WeChatMCP",
    "transportType": "stdio",
    "httpStream": {
      "host": "127.0.0.1",
      "port": 3333,
      "endpoint": "/mcp",
      "enableJsonResponse": true,
      "stateless": false
    },
    "health": {
      "enabled": true,
      "path": "/health",
      "message": "ok",
      "status": 200
    }
  },
  "connection": {
    "port": 9420,
    "timeout": 30000,
    "trustProject": true,
    "autoClose": false
  },
  "ciDefaults": {
    "robot": 1,
    "qrcodeFormat": "terminal"
  }
}
